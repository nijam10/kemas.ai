// Kemas.ai Database Schema
// AI-powered packaging design platform for Indonesian UMKM
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts (Prisma 7+)
  // See: https://www.prisma.io/docs/orm/reference/prisma-config-reference
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum CreditTransactionType {
  DAILY_RESET       // Daily quota reset
  GENERATION_USAGE  // Credits used for AI generation
  ADMIN_TOPUP       // Admin manually adds credits
  ADMIN_RESET       // Admin resets to daily quota
  REFUND            // Refund for failed generation
}

enum PackagingType {
  STANDING_POUCH
  PILLOW_POUCH
  BOX
  JAR
  BOTTLE
  SACHET
}

enum DesignStatus {
  PROCESSING  // AI generation in progress
  COMPLETED   // Successfully generated
  FAILED      // Generation failed
  FLAGGED     // Flagged by moderation
}

enum GenerationJobStatus {
  QUEUED      // Waiting in queue
  RUNNING     // Currently processing
  COMPLETED   // Successfully completed
  FAILED      // Failed with error
  CANCELLED   // Cancelled by user or system
}

enum GenerationStep {
  CREDIT_CHECK        // Verifying user has enough credits
  API_GATEWAY         // Sending request to RunPod
  COMFYUI_PIPELINE    // ComfyUI workflow execution
  LORA_STYLE          // Applying LoRA style model
  LOGO_COMPOSITING    // Compositing user logo
  OUTPUT_READY        // Final image generated
  PREVIEW_READY       // Preview/thumbnail ready
}

enum GalleryCategory {
  FOOD_BEVERAGES
  ARTISAN_SNACK
  MODERN_MINIMAL
  TRADITIONAL
  ORGANIC
  PREMIUM_COFFEE
  HEALTHY_PRODUCTS
}

enum ModerationType {
  PROMPT        // Reviewing user prompt text
  IMAGE         // Reviewing generated image
  USER_REPORT   // User-reported content
}

enum ModerationStatus {
  PENDING   // Awaiting review
  APPROVED  // Approved by admin
  FLAGGED   // Flagged for issues
  REMOVED   // Removed from platform
}

enum AdminAction {
  SUSPEND_USER
  ACTIVATE_USER
  TOPUP_CREDIT
  RESET_CREDIT
  APPROVE_CONTENT
  FLAG_CONTENT
  REMOVE_CONTENT
}

enum AssetType {
  LOGO              // User uploaded logo
  GENERATED_IMAGE   // AI generated design
  THUMBNAIL         // Thumbnail/preview image
}

// ============================================================
// USER & AUTHENTICATION
// ============================================================

/// User account model
/// Stores user profile, authentication, and business information
model User {
  id               String     @id @default(uuid())
  name             String
  email            String     @unique
  emailVerified    DateTime?
  image            String?
  role             UserRole   @default(USER)
  status           UserStatus @default(ACTIVE)
  profile          UserProfile?

  businessName     String?
  businessCategory String?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  accounts             Account[]
  sessions             Session[]
  creditWallet         CreditWallet?
  creditTransactions   CreditTransaction[]
  designs              Design[]
  generationJobs       GenerationJob[]
  uploadedAssets       UploadedAsset[]
  moderationLogs       ModerationLog[]      @relation("ModeratedUser")
  moderationReviews    ModerationLog[]      @relation("ModerationAdmin")
  adminActions         AdminActionLog[]     @relation("AdminActionActor")
  targetedAdminActions AdminActionLog[]     @relation("AdminActionTarget")

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

// ── Auth.js required models ───────────────────────────────────────────────────

/// OAuth account linked to a user (Google, GitHub, etc.)
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

/// Auth.js database session (used when strategy = "database")
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

/// Email verification tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// User workspace preferences and business profile settings
/// Created on first save; one-to-one with User
model UserProfile {
  id                      String   @id @default(uuid())
  userId                  String   @unique

  // Business identity
  businessName            String?
  brandCategory           String?  // e.g., "Food & Beverages"

  // Workspace preferences
  defaultPackagingType    String   @default("Standing Pouch")
  defaultExportQuality    String   @default("High Resolution")
  autoSaveGeneratedDesigns Boolean @default(true)

  // Timestamps
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  // Relations
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_profiles")
}

// ============================================================
// CREDIT SYSTEM
// ============================================================

/// Credit wallet for each user
/// Stores current balance and daily quota information
model CreditWallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  balance     Int      @default(40) // Current available credits
  dailyQuota  Int      @default(40) // Daily reset amount
  lastResetAt DateTime @default(now()) // Last daily reset timestamp
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("credit_wallets")
}

/// Credit transaction history
/// Tracks all credit movements (usage, top-ups, resets, refunds)
model CreditTransaction {
  id          String                @id @default(uuid())
  userId      String
  amount      Int                   // Positive for add, negative for deduct
  type        CreditTransactionType
  description String?               // Human-readable description
  referenceId String?               // Reference to Design/Job ID if applicable
  
  // Timestamps
  createdAt   DateTime              @default(now())
  
  // Relations
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("credit_transactions")
}

// ============================================================
// DESIGN & GENERATION
// ============================================================

/// Generated packaging design
/// Stores user's generated designs and their metadata
model Design {
  id              String         @id @default(uuid())
  userId          String
  
  // Design metadata
  title           String         // User-provided or auto-generated title
  prompt          String         @db.Text // User's generation prompt
  negativePrompt  String?        @db.Text // Negative prompt for quality control
  seed            Int?           // Random seed for reproducibility
  packagingType   PackagingType
  
  // Asset URLs
  imageUrl        String?        // Final generated image URL
  wrapperUrl      String?        // Flat 2D layout wrapper image URL
  logoUrl         String?        // User's uploaded logo URL
  thumbnailUrl    String?        // Thumbnail for gallery/history
  
  // Status & metadata
  status          DesignStatus   @default(PROCESSING)
  creditsUsed     Int            @default(10) // Credits consumed for this generation
  isSaved         Boolean        @default(false) // User saved to favorites
  isPublished     Boolean        @default(false) // Whether design has been published to gallery
  
  // Timestamps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Relations
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJob   GenerationJob?
  moderationLogs  ModerationLog[]
  
  @@index([userId])
  @@index([status])
  @@index([packagingType])
  @@index([createdAt])
  @@map("designs")
}

/// AI generation job tracking
/// Tracks the status of RunPod/ComfyUI generation pipeline
model GenerationJob {
  id               String              @id @default(uuid())
  userId           String
  designId         String              @unique
  
  // External service IDs
  runpodJobId      String?             // RunPod job identifier
  comfyWorkflowId  String?             // ComfyUI workflow identifier
  
  // Job status
  status           GenerationJobStatus @default(QUEUED)
  currentStep      GenerationStep?     // Current pipeline step
  errorMessage     String?             @db.Text // Error details if failed
  
  // Timestamps
  startedAt        DateTime?           // When job started processing
  completedAt      DateTime?           // When job finished (success or fail)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  
  // Relations
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  design           Design              @relation(fields: [designId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@index([runpodJobId])
  @@index([createdAt])
  @@map("generation_jobs")
}

// ============================================================
// GALLERY TEMPLATES (NOT USER HISTORY)
// ============================================================

/// Gallery template presets
/// Reusable design templates/presets for inspiration
/// NOT the same as user's design history
model GalleryTemplate {
  id              String          @id @default(uuid())
  
  // Template metadata
  title           String
  slug            String          @unique // URL-friendly identifier
  description     String?         @db.Text
  category        GalleryCategory
  packagingType   PackagingType
  
  // Visual assets
  previewImageUrl String          // Template preview image
  
  // Generation presets
  promptPreset    String          @db.Text // Pre-filled prompt template
  negativePrompt  String?         @db.Text
  seed            Int?
  colorMood       String?         // e.g., "warm", "cool", "vibrant"
  styleTags       String[]        // e.g., ["minimalist", "modern", "elegant"]
  
  // Featured flag
  isFeatured      Boolean         @default(false)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([category])
  @@index([slug])
  @@index([isFeatured])
  @@index([packagingType])
  @@map("gallery_templates")
}

// ============================================================
// MODERATION & ADMIN
// ============================================================

/// Content moderation log
/// Tracks admin review of prompts and generated images
model ModerationLog {
  id        String           @id @default(uuid())
  designId  String
  userId    String           // User who created the content
  adminId   String           // Admin who reviewed
  
  // Moderation details
  type      ModerationType
  status    ModerationStatus @default(PENDING)
  reason    String?          @db.Text // Reason for flagging/removal
  
  // Timestamps
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  
  // Relations
  design    Design           @relation(fields: [designId], references: [id], onDelete: Cascade)
  user      User             @relation("ModeratedUser", fields: [userId], references: [id], onDelete: Cascade)
  admin     User             @relation("ModerationAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  
  @@index([designId])
  @@index([userId])
  @@index([adminId])
  @@index([status])
  @@index([type])
  @@map("moderation_logs")
}

/// Admin action audit log
/// Tracks all admin actions for accountability
model AdminActionLog {
  id           String      @id @default(uuid())
  adminId      String      // Admin who performed action
  targetUserId String?     // User affected by action (if applicable)
  
  // Action details
  action       AdminAction
  description  String      @db.Text // Human-readable description
  metadata     Json?       // Additional structured data (e.g., credit amount, reason)
  
  // Timestamp
  createdAt    DateTime    @default(now())
  
  // Relations
  admin        User        @relation("AdminActionActor", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser   User?       @relation("AdminActionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  
  @@index([adminId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_action_logs")
}

// ============================================================
// ASSET MANAGEMENT
// ============================================================

/// Uploaded assets (logos, images)
/// Tracks all user-uploaded and system-generated files
model UploadedAsset {
  id        String    @id @default(uuid())
  userId    String
  
  // Asset details
  type      AssetType
  fileUrl   String    // Cloud storage URL (e.g., S3, Cloudinary)
  fileName  String
  mimeType  String    // e.g., "image/png", "image/jpeg"
  size      Int       // File size in bytes
  
  // Timestamp
  createdAt DateTime  @default(now())
  
  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("uploaded_assets")
}
